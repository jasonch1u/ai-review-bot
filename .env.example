# GitHub App credentials
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
# Temporary installation token (replace with proper App JWT exchange in production)
GITHUB_INSTALLATION_TOKEN=

# GitHub App name (slug used in install URLs, e.g. "my-review-bot")
GITHUB_APP_NAME=ai-review-bot
# Exposed to the browser for onboarding page links
NEXT_PUBLIC_GITHUB_APP_NAME=ai-review-bot

# Claude / Anthropic API
ANTHROPIC_API_KEY=

# App URL (used for GitHub App callback)
NEXT_PUBLIC_APP_URL=http://localhost:3000
